# New Relic 설정
NEWRELIC_API_KEY=REPLACE_WITH_NEW_USER_KEY
NEWRELIC_ACCOUNT_ID=7617380
NEWRELIC_APP_NAME=pongift-partners-api
NEWRELIC_HOSTNAME_LIKE=dev%

# Slack Incoming Webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXX/XXXXX/XXXXX

# 스케줄
# 1시간마다
SCHEDULE_INTERVAL=0 0 * * * *

# 시간대 / 로그
TIMEZONE=Asia/Seoul
LOG_DIR=./logs

# 알림 세부 옵션
ENABLE_CHANNEL_MENTION_ON_CRITICAL=true
